# Copy to .env and fill in values

# PTV OpenData API key — required for real-time delays
PTV_API_KEY=your_ptv_api_key_here

# Shared secret between the server and web frontend.
# Leave empty for local-only use (Android widget doesn't need it).
NEXTTRAIN_API_KEY=

# CORS origin for the web frontend (Netlify / GitHub Pages URL).
# Leave empty if not hosting a web frontend.
FRONTEND_ORIGIN=https://nexttrain.netlify.app

# Path to the directory containing your cloudflared tunnel credentials.
# Defaults to ~/.cloudflared — only needed if you moved the creds file.
# CF_CREDS_DIR=~/.cloudflared
