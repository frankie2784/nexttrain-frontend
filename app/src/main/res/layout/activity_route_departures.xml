<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nt_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/nt_text"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Next 3 Trains"
                android:textColor="@color/nt_text"
                android:textStyle="bold"
                android:textSize="24sp" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_route_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Origin → Destination"
            android:textColor="@color/nt_text"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/nt_muted"
            android:textSize="14sp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/departures_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />


        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="No trains found"
            android:textColor="@color/nt_muted"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_route_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable notifications for this route"
            android:textColor="@color/nt_text"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Refresh"
                android:backgroundTint="@color/nt_secondary"
                android:textColor="@color/nt_on_primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_back_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back"
                android:backgroundTint="@color/nt_primary"
                android:textColor="@color/nt_on_primary" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
