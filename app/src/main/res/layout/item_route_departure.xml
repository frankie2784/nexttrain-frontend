<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/nt_surface"
    app:strokeColor="@color/nt_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_dep_mins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="8 min"
            android:textColor="@color/nt_primary_dark"
            android:textStyle="bold"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tv_dep_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. 07:45"
            android:textColor="@color/nt_text"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_dep_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Platform 1"
            android:textColor="@color/nt_muted"
            android:textSize="14sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
