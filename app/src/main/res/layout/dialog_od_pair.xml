<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/nt_surface"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Label (e.g. Morning commute)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:textColorHint="@color/nt_muted"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/nt_text"
            android:textColorHint="@color/nt_muted" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Origin station"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/nt_text"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_origin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Destination station"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/nt_text"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_destination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active time window"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/nt_text"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From"
                android:textColor="@color/nt_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_time_from"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="06:00"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/nt_text"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="–"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textSize="24sp"
            android:textColor="@color/nt_muted"
            android:paddingHorizontal="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To"
                android:textColor="@color/nt_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_time_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="10:00"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/nt_text"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active days"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/nt_text"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/day_toggle_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:singleSelection="false"
        app:selectionRequired="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_sun"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Su"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_mon"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Mo"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_tue"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Tu"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_wed"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="We"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_thu"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Th"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_fri"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Fr"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cb_sat"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Sa"
            android:textAllCaps="false"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:checkable="true"
            app:cornerRadius="0dp" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
